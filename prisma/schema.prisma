generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum DocPageType {
  REFERENCE_INDEX
  REFERENCE_ITEM
  GUIDE
  CHANGELOG
  CHANGELOG_VERSION
  UNKNOWN
}

enum DocFetchMode {
  DEFAULT
  NOSCRIPT
}

enum DocRelationType {
  DISCOVERED_CHILD
  CHANGELOG_ENTRY
  RELATED
}

enum DocSyncRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model DocSource {
  id          String       @id @default(cuid())
  slug        String       @unique
  label       String
  baseUrl     String
  allowedPath String
  seedUrls    Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  pages       DocPage[]
  syncRuns    DocSyncRun[]
}

model DocPage {
  id               String        @id @default(cuid())
  sourceId         String
  url              String        @unique
  canonicalUrl     String?
  path             String
  slug             String?
  title            String?
  pageType         DocPageType   @default(UNKNOWN)
  latestSnapshotId String?
  firstSeenAt      DateTime      @default(now())
  lastSeenAt       DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  source           DocSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  snapshots        DocSnapshot[]
  outgoingLinks    DocLink[]     @relation("DocLinkFromPage")
  incomingLinks    DocLink[]     @relation("DocLinkToPage")
  changes          DocChange[]

  @@index([sourceId, pageType, updatedAt])
  @@index([sourceId, path])
  @@index([latestSnapshotId])
}

model DocSnapshot {
  id              String       @id @default(cuid())
  pageId          String
  requestUrl      String
  responseUrl     String
  fetchMode       DocFetchMode @default(DEFAULT)
  httpStatus      Int
  responseHeaders Json
  rawHtml         String
  rawText         String?
  contentHash     String
  extractedData   Json?
  parserVersion   String
  fetchedAt       DateTime     @default(now())
  page            DocPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  outgoingLinks   DocLink[]

  @@index([pageId, fetchedAt])
  @@index([contentHash])
}

model DocLink {
  id             String          @id @default(cuid())
  fromSnapshotId String?
  fromPageId     String
  toPageId       String?
  targetUrl      String
  relationType   DocRelationType
  anchorText     String?
  sourceHint     String?
  createdAt      DateTime        @default(now())
  fromSnapshot   DocSnapshot?    @relation(fields: [fromSnapshotId], references: [id], onDelete: Cascade)
  fromPage       DocPage         @relation("DocLinkFromPage", fields: [fromPageId], references: [id], onDelete: Cascade)
  toPage         DocPage?        @relation("DocLinkToPage", fields: [toPageId], references: [id], onDelete: SetNull)

  @@index([fromPageId, relationType])
  @@index([toPageId, relationType])
  @@index([targetUrl])
}

model DocChange {
  id                 String   @id @default(cuid())
  pageId             String
  previousSnapshotId String?
  currentSnapshotId  String
  previousHash       String?
  currentHash        String
  summary            Json?
  createdAt          DateTime @default(now())
  page               DocPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, createdAt])
}

model DocSyncRun {
  id              String           @id @default(cuid())
  sourceId        String
  status          DocSyncRunStatus @default(RUNNING)
  trigger         String
  requestedBy     String?
  maxPages        Int?
  pagesDiscovered Int              @default(0)
  pagesFetched    Int              @default(0)
  pagesChanged    Int              @default(0)
  error           String?
  startedAt       DateTime         @default(now())
  finishedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  source          DocSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt])
  @@index([status, createdAt])
}
