# SQLite path relative to the repo root.
DATABASE_URL="file:./prisma/dev.db"

# Optional local server overrides.
PORT="3002"
HOST="127.0.0.1"

# Extraction diagnostics for sync runs.
DOCS_LOG_EXTRACTION="1"
# Set to 1 to log every page even when there are no obvious gaps.
DOCS_LOG_EXTRACTION_VERBOSE="0"

# Pace missing-page imports so we do not hammer the docs host.
DOCS_IMPORT_DELAY_MS="1250"
DOCS_IMPORT_JITTER_MS="350"
